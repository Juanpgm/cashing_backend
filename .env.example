# Database
DATABASE_URL=postgresql+asyncpg://cashin:password@localhost:5432/cashin

# JWT
JWT_SECRET_KEY=your-secret-key-min-32-chars-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
# STORAGE_PROVIDER: "s3" for AWS S3 / Cloudflare R2, "minio" for local dev
STORAGE_PROVIDER=minio
# S3_ENDPOINT_URL: leave empty for native AWS S3; set for MinIO (local) or Cloudflare R2
# Local dev: S3_ENDPOINT_URL=http://localhost:9000
S3_ENDPOINT_URL=
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=auto
S3_BUCKET_EVIDENCIAS=cashin-evidencias
S3_BUCKET_DOCUMENTOS=cashin-documentos
S3_BUCKET_PDFS=cashin-pdfs

# LLM — usando Groq (gratuito, rápido, modelos Llama/Qwen)
# Obtén tu key en: https://console.groq.com/keys
LLM_DEFAULT_MODEL=groq/llama-3.1-8b-instant
LLM_FALLBACK_MODEL=groq/llama3-8b-8192
LLM_LOCAL_MODEL=ollama/qwen2.5:7b
# LLM_EXTRACTION_MODEL: modelo dedicado para extracción de obligaciones de contratos.
# Usar un modelo más capaz para mayor precisión en la extracción.
LLM_EXTRACTION_MODEL=groq/llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integraciones/google/callback

# Wompi
WOMPI_PUBLIC_KEY=pub_test_xxx
WOMPI_PRIVATE_KEY=prv_test_xxx
WOMPI_EVENTS_SECRET=test_events_xxx
WOMPI_API_URL=https://sandbox.wompi.co/v1

# App
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:19006","http://localhost:3000"]
TOKEN_ENCRYPTION_KEY=your-fernet-key-here

# Credits
CREDITS_PER_CUENTA_COBRO=10
CREDITS_PER_CHAT_MESSAGE=1
CREDITS_PER_EVIDENCE_COLLECTION=5
FREE_CREDITS_ON_SIGNUP=30

# SECOP API (datos.gov.co)
SECOP_APP_TOKEN=
